{
  "name": "behaix",
  "version": "0.0.0",
  "private": true,
  "description": "A startup-grade enterprise design system in React, TypeScript, Tailwind CSS, CVA, Radix UI, and Storybook.",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  },
  "scripts": {
    "build": "pnpm -r build",
    "changeset": "changeset",
    "dev": "pnpm storybook",
    "format": "prettier --write .",
    "lint": "eslint .",
    "release": "pnpm build && changeset publish",
    "storybook": "pnpm --filter @behaix/docs storybook",
    "test": "pnpm --filter @behaix/components test",
    "test:watch": "pnpm --filter @behaix/components test:watch",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.12",
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.10.7",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "eslint": "^9.18.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-storybook": "^0.11.2",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  }
}