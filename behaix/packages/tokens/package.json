{
  "name": "@behaix/tokens",
  "version": "0.0.0",
  "description": "Design tokens for Behaix.",
  "license": "MIT",
  "type": "module",
  "sideEffects": ["./dist/tokens.css"],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./tokens.css": "./dist/tokens.css",
    "./tokens.json": "./dist/tokens.json"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && cp src/tokens.css dist/tokens.css && cp src/tokens.json dist/tokens.json",
    "typecheck": "tsc -p tsconfig.json"
  },
  "devDependencies": {
    "typescript": "^5.7.3"
  }
}
