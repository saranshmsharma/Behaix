{
  "version": 2,
  "framework": "storybook",
  "buildCommand": "pnpm build",
  "installCommand": "npm install -g pnpm@10 && pnpm install --no-frozen-lockfile",
  "outputDirectory": "packages/docs/storybook-static",
  "build": {
    "env": {
      "NODE_VERSION": "20"
    }
  },
  "cleanUrls": true,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        }
      ]
    }
  ]
}
