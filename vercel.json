{
  "version": 2,
  "framework": "storybook",
  "buildCommand": "npx --yes pnpm@10.11.0 build",
  "installCommand": "npx --yes pnpm@10.11.0 install --no-frozen-lockfile",
  "outputDirectory": "packages/docs/storybook-static",

  "cleanUrls": true,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        }
      ]
    }
  ]
}
